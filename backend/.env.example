# ShellCraft backend environment.
# Copy to `.env` for local development and adjust as needed.

# Async SQLAlchemy URL (must use the asyncpg driver for Postgres).
DATABASE_URL=postgresql+asyncpg://shellcraft:shellcraft@localhost:5432/shellcraft

# Redis connection used for server-side session storage.
REDIS_URL=redis://localhost:6379/0

# Session cookie configuration.
SESSION_COOKIE_NAME=shellcraft_session
SESSION_TTL_SECONDS=604800
SESSION_COOKIE_SECURE=false
SESSION_COOKIE_SAMESITE=lax

# XP required per level-up step.
XP_PER_LEVEL=500

# Opt-in Docker sandbox (see ADR-0002); unrelated to persistence.
# SHELLCRAFT_SANDBOX=1
